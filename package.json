{
  "name": "metabot",
  "version": "1.1.0",
  "metabotEdition": "personal",
  "description": "MetaBot Personal Edition — use Codex and Kimi Code from IM channels and the local Web UI",
  "main": "dist/index.js",
  "type": "module",
  "workspaces": [
    "packages/cli",
    "packages/cli-core",
    "packages/metamemory",
    "packages/skill-hub",
    "packages/server",
    "packages/web-ui"
  ],
  "scripts": {
    "build": "npm run build:web && tsc -b --force && npm run build -w @xvirobotics/metabot-core-web-ui && npm run pack:standalone -w @xvirobotics/cli && npm run pack:metabot -w @xvirobotics/metabot-core-server",
    "build:bridge": "tsc -p tsconfig.bridge.json",
    "build:web": "cd web && npm install --include=dev && ./node_modules/.bin/vite build",
    "build:packages": "npm run build --workspaces --if-present",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run && npm run test --workspaces --if-present",
    "test:bridge": "vitest run",
    "test:packages": "npm run test --workspaces --if-present",
    "lint": "eslint src/ tests/ && npm run lint --workspaces --if-present",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "pack:github": "bash scripts/pack-github-release.sh",
    "update-cli": "cp bin/metabot ~/.local/bin/metabot && chmod +x ~/.local/bin/metabot && echo \"Updated: metabot\" && rm -f ~/.local/bin/mb ~/.local/bin/mm ~/.local/bin/mh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.154",
    "@anthropic-ai/sdk": "^0.100.0",
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "@types/ws": "^8.18.0",
    "@volcengine/openapi": "^1.36.0",
    "@xterm/headless": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.4.0",
    "grammy": "^1.40.0",
    "https-proxy-agent": "^7.0.6",
    "mammoth": "^1.12.0",
    "marked": "^18.0.3",
    "node-edge-tts": "^1.2.10",
    "node-pty": "^1.1.0",
    "openai": "^6.29.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "undici": "^7.28.0",
    "ws": "^8.21.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "axios": "^1.15.2",
    "buffer": "^6.0.3",
    "form-data": "^4.0.6",
    "hono": "^4.12.25",
    "protobufjs": "^7.6.3",
    "uuid": "^11.1.1"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
